# LLM Configuration
ECOM_LLM_API_KEY=your_api_key_here
ECOM_LLM_BASE_URL=https://api.minimax.chat/v1
ECOM_LLM_MODEL=MiniMax-M1

# Redis
ECOM_REDIS_URL=redis://localhost:6379/0

# Milvus
ECOM_MILVUS_HOST=localhost
ECOM_MILVUS_PORT=19530
ECOM_MILVUS_COLLECTION=amazon_electronics_products

# Amazon Reviews RAG
ECOM_DATA_RAW_DIR=../data/raw
ECOM_DATA_PROCESSED_DIR=../data/processed
ECOM_AMAZON_CATEGORY=Electronics
ECOM_AMAZON_MAX_PRODUCTS=1000
ECOM_AMAZON_MAX_REVIEWS=10000
ECOM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ECOM_EMBEDDING_DIMENSION=384
